{
    "info": {
        "name": "Gym Backend API",
        "description": "Admin Authentication, Blog, Contact Us, Gym Plan, and User Enquiry API for Gym Backend",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "admin_token",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
            {
                "name": "User Enquiry",
                "item": [
                    {
                        "name": "Create Enquiry",
                        "request": {
                            "method": "POST",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json",
                                    "type": "text"
                                }
                            ],
                            "body": {
                                "mode": "raw",
                                "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"message\": \"I would like more information about membership plans.\"\n}"
                            },
                            "url": {
                                "raw": "{{base_url}}/api/enquiries",
                                "host": [
                                    "{{base_url}}"
                                ],
                                "path": [
                                    "api",
                                    "enquiries"
                                ]
                            },
                            "description": "Create a new user enquiry"
                        },
                        "response": []
                    },
                    {
                        "name": "Get All Enquiries",
                        "request": {
                            "method": "GET",
                            "header": [
                                {
                                    "key": "Authorization",
                                    "value": "Bearer {{admin_token}}",
                                    "type": "text"
                                }
                            ],
                            "url": {
                                "raw": "{{base_url}}/api/enquiries",
                                "host": [
                                    "{{base_url}}"
                                ],
                                "path": [
                                    "api",
                                    "enquiries"
                                ]
                            },
                            "description": "Retrieve all user enquiries (admin only)"
                        },
                        "response": []
                    },
                    {
                        "name": "Mark Enquiry as Read",
                        "request": {
                            "method": "PATCH",
                            "header": [
                                {
                                    "key": "Authorization",
                                    "value": "Bearer {{admin_token}}",
                                    "type": "text"
                                }
                            ],
                            "url": {
                                "raw": "{{base_url}}/api/enquiries/:id/read",
                                "host": [
                                    "{{base_url}}"
                                ],
                                "path": [
                                    "api",
                                    "enquiries",
                                    ":id",
                                    "read"
                                ],
                                "variable": [
                                    {
                                        "key": "id",
                                        "value": "enquiry_id_here",
                                        "description": "Enquiry ID to mark as read"
                                    }
                                ]
                            },
                            "description": "Mark a user enquiry as read (admin only)"
                        },
                        "response": []
                    }
                ]
            },
            {
                "name": "Admin Auth",
                "item": [
                    {
                        "name": "Send OTP",
                        "request": {
                            "method": "POST",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json",
                                    "type": "text"
                                }
                            ],
                            "body": {
                                "mode": "raw",
                                "raw": "{\n  \"email\": \"admin@example.com\"\n}"
                            },
                            "url": {
                                "raw": "{{base_url}}/api/admin/auth/send-otp",
                                "host": [
                                    "{{base_url}}"
                                ],
                                "path": [
                                    "api",
                                    "admin",
                                    "auth",
                                    "send-otp"
                                ]
                            },
                            "description": "Send OTP to admin email address"
                        },
                        "response": []
                    },
                    {
                        "name": "Verify OTP",
                        "event": [
                            {
                                "listen": "test",
                                "script": {
                                    "exec": [
                                        "if (pm.response.code === 200) {",
                                        "  const response = pm.response.json();",
                                        "  if (response.token) {",
                                        "    pm.environment.set('admin_token', response.token);",
                                        "  }",
                                        "}"
                                    ]
                                }
                            }
                        ],
                        "request": {
                            "method": "POST",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json",
                                    "type": "text"
                                }
                            ],
                            "body": {
                                "mode": "raw",
                                "raw": "{\n  \"email\": \"admin@example.com\",\n  \"otp\": \"123456\"\n}"
                            },
                            "url": {
                                "raw": "{{base_url}}/api/admin/auth/verify-otp",
                                "host": [
                                    "{{base_url}}"
                                ],
                                "path": [
                                    "api",
                                    "admin",
                                    "auth",
                                    "verify-otp"
                                ]
                            },
                            "description": "Verify OTP and get JWT token"
                        },
                        "response": []
                    },
                    {
                        "name": "Get Admin Profile",
                        "request": {
                            "method": "GET",
                            "header": [
                                {
                                    "key": "Authorization",
                                    "value": "Bearer {{admin_token}}",
                                    "type": "text"
                                }
                            ],
                            "url": {
                                "raw": "{{base_url}}/api/admin/auth/profile",
                                "host": [
                                    "{{base_url}}"
                                ],
                                "path": [
                                    "api",
                                    "admin",
                                    "auth",
                                    "profile"
                                ]
                            },
                            "description": "Get admin profile information using authentication token"
                        },
                        "response": []
                    },
                    {
                        "name": "Update Admin Profile",
                        "request": {
                            "method": "PUT",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json",
                                    "type": "text"
                                },
                                {
                                    "key": "Authorization",
                                    "value": "Bearer {{admin_token}}",
                                    "type": "text"
                                }
                            ],
                            "body": {
                                "mode": "raw",
                                "raw": "{\n  \"username\": \"admin_username\",\n  \"email\": \"admin@example.com\",\n  \"profilePicture\": \"https://res.cloudinary.com/demo/image/upload/sample.jpg\"\n}"
                            },
                            "url": {
                                "raw": "{{base_url}}/api/admin/auth/profile",
                                "host": [
                                    "{{base_url}}"
                                ],
                                "path": [
                                    "api",
                                    "admin",
                                    "auth",
                                    "profile"
                                ]
                            },
                            "description": "Update admin profile information with raw JSON body"
                        },
                        "response": []
                    },
                    {
                        "name": "Generate Upload Signature",
                        "request": {
                            "method": "POST",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json",
                                    "type": "text"
                                },
                                {
                                    "key": "Authorization",
                                    "value": "Bearer {{admin_token}}",
                                    "type": "text"
                                }
                            ],
                            "url": {
                                "raw": "{{base_url}}/api/admin/auth/generate-upload-signature",
                                "host": [
                                    "{{base_url}}"
                                ],
                                "path": [
                                    "api",
                                    "admin",
                                    "auth",
                                    "generate-upload-signature"
                                ]
                            },
                            "description": "Generate a Cloudinary upload signature for admin profile uploads"
                        },
                        "response": []
                    },
                    {
                        "name": "Logout Admin",
                        "request": {
                            "method": "POST",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json",
                                    "type": "text"
                                },
                                {
                                    "key": "Authorization",
                                    "value": "Bearer {{admin_token}}",
                                    "type": "text"
                                }
                            ],
                            "body": {
                                "mode": "raw",
                                "raw": "{}"
                            },
                            "url": {
                                "raw": "{{base_url}}/api/admin/auth/logout",
                                "host": [
                                    "{{base_url}}"
                                ],
                                "path": [
                                    "api",
                                    "admin",
                                    "auth",
                                    "logout"
                                ]
                            },
                            "description": "Logout admin and revoke token"
                        },
                        "response": []
                    }
                ]
            },
