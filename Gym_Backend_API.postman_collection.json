{
    "info": {
        "name": "Gym Backend API",
        "description": "Admin Authentication, Blog, and Contact Us API for Gym Backend",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "admin_token",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Admin Auth",
            "item": [
                {
                    "name": "Send OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@example.com\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/admin/auth/send-otp",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "auth",
                                "send-otp"
                            ]
                        },
                        "description": "Send OTP to admin email address"
                    },
                    "response": []
                },
                {
                    "name": "Verify OTP",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "  const response = pm.response.json();",
                                    "  if (response.token) {",
                                    "    pm.environment.set('admin_token', response.token);",
                                    "  }",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@example.com\",\n  \"otp\": \"123456\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/admin/auth/verify-otp",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "auth",
                                "verify-otp"
                            ]
                        },
                        "description": "Verify OTP and get JWT token"
                    },
                    "response": []
                },
                {
                    "name": "Update Admin Profile",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "multipart/form-data",
                                "type": "text"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "username",
                                    "value": "admin_username",
                                    "type": "text"
                                },
                                {
                                    "key": "email",
                                    "value": "admin@example.com",
                                    "type": "text"
                                },
                                {
                                    "key": "profilePicture",
                                    "type": "file",
                                    "src": ""
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/api/admin/auth/profile",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "auth",
                                "profile"
                            ]
                        },
                        "description": "Update admin profile information and profile picture"
                    },
                    "response": []
                },
                {
                    "name": "Generate Upload Signature",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/admin/auth/generate-upload-signature",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "auth",
                                "generate-upload-signature"
                            ]
                        },
                        "description": "Generate a Cloudinary upload signature for admin profile uploads"
                    },
                    "response": []
                },
                {
                    "name": "Logout Admin",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/admin/auth/logout",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "auth",
                                "logout"
                            ]
                        },
                        "description": "Logout admin and revoke token"
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Blog",
            "item": [
                {
                    "name": "Create Blog",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"My First Blog\",\n  \"content\": \"This is the blog content.\",\n  \"blogImage\": \"https://res.cloudinary.com/demo/image/upload/sample.jpg\",\n  \"public_id\": \"sample_public_id\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/blogs/blogs",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "blogs",
                                "blogs"
                            ]
                        },
                        "description": "Create a new blog entry"
                    },
                    "response": []
                },
                {
                    "name": "Get All Blogs",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/blogs/blogs",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "blogs",
                                "blogs"
                            ]
                        },
                        "description": "Get all blog entries"
                    },
                    "response": []
                },
                {
                    "name": "Delete Blog",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/blogs/blogs/:id",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "blogs",
                                "blogs",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "blog_id_here",
                                    "description": "Blog ID to delete"
                                }
                            ]
                        },
                        "description": "Delete a blog entry by ID"
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Contact Us",
            "item": [
                {
                    "name": "Create Contact",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"contact@example.com\",\n  \"Address\": \"123 Main Street, City, State 12345\",\n  \"phone\": \"+1234567890\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/contactUs",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "contactUs"
                            ]
                        },
                        "description": "Create a new contact entry"
                    },
                    "response": []
                },
                {
                    "name": "Get All Contacts",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/contactUs",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "contactUs"
                            ]
                        },
                        "description": "Retrieve all contact entries"
                    },
                    "response": []
                },
                {
                    "name": "Update Contact",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"updated@example.com\",\n  \"Address\": \"456 Updated Street, City, State 67890\",\n  \"phone\": \"+0987654321\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/contactUs/:id",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "contactUs",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "contact_id_here",
                                    "description": "Contact ID to update"
                                }
                            ]
                        },
                        "description": "Update an existing contact entry by ID"
                    },
                    "response": []
                },
                {
                    "name": "Delete Contact",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/contactUs/:id",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "contactUs",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "contact_id_here",
                                    "description": "Contact ID to delete"
                                }
                            ]
                        },
                        "description": "Delete a contact entry by ID"
                    },
                    "response": []
                }
            ]
        }
    ]
}